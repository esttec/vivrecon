# Copy this file to ".env" on the server and fill in real values.
# NEVER commit the real .env to git.

# A long random password for the database (make one up, 20+ characters).
DB_PASS=change-this-to-a-long-random-password

# A long random string (32+ characters) used to sign login tokens.
JWT_SECRET=change-this-to-a-very-long-random-secret-string-32-chars-min

# Your Google Gemini API key (for the AI assistant).
GEMINI_API_KEY=your-gemini-key

# Stripe — start with TEST keys to verify the live site, then switch to LIVE keys.
STRIPE_SECRET_KEY=sk_test_or_sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_MONTHLY=price_your_monthly_id
STRIPE_PRICE_YEARLY=price_your_yearly_id
